# Python
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Secrets & local state — never commit
.env
.env.*
# data/: local state stays out, EXCEPT the non-secret JSONs the GitHub Pages
# build commits back for persistence (track record, AI brief, RE archive).
data/*
!data/track_predictions.json
!data/track_scores.json
!data/ai_brief.json
!data/realestate_us_archive.json
!data/state_snapshot.json
!data/krw_mirror.json
*.log
*.sqlite
*.sqlite3
*.db
**/claude_oauth_token.txt
**/.credentials.json

# GitHub Pages build artifact (regenerated every run)
site/
